APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Dev default writes mail to the log. For password-reset links to actually be delivered, set
# MAIL_MAILER=smtp (or ses/postmark/...) with the credentials below on the deploy platform.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#===============================================================================
# Laravel IAM — core
#===============================================================================
# Issuer of the OAuth/OIDC tokens. In production set to your public URL (must
# match APP_URL), e.g. https://iam.yourcompany.com. Empty = APP_URL.
IAM_ISSUER=

# Key management for signing/envelope keys. `local` keeps ES256 signing keys in
# the DB (iam_signing_keys, auto-generated) with the KEK below. `aws` uses AWS KMS.
IAM_KMS_DRIVER=local

# Envelope-encryption KEK and OAuth (auth code / refresh) encryption key. In dev,
# leave EMPTY to derive them from APP_KEY. In PRODUCTION set explicit 32-byte
# base64 secrets: `openssl rand -base64 32` (or `php artisan iam:... ` — see docs).
IAM_KEK=
IAM_OAUTH_ENCRYPTION_KEY=

# On Windows dev only: path to an openssl.cnf so EC key generation works.
# IAM_OPENSSL_CONF=

# Expected audience of Admin API Bearer tokens. Leave EMPTY for the bundled
# session-authenticated console; set it only if you also expose the Admin API to
# external Bearer-token clients.
IAM_ADMIN_AUDIENCE=

# Run the package migrations automatically (default true).
IAM_RUN_MIGRATIONS=true

# First super-admin, created by `php artisan db:seed`. CHANGE THESE before deploying.
IAM_SUPERADMIN_NAME="Super Admin"
IAM_SUPERADMIN_EMAIL=admin@example.com
IAM_SUPERADMIN_PASSWORD=change-me-now

#===============================================================================
# Console login 2FA (optional). TOTP via Fortify; enrol under the Security screen.
#===============================================================================
IAM_CONSOLE_2FA=false

#===============================================================================
# OAuth client credential lifecycle (optional). All *_TTL / *_GRACE are in SECONDS.
#===============================================================================
# Scheduled expiry of a NEW/rotated client secret (empty = never; only drives alerts, expiry is soft).
# IAM_OAUTH_CLIENT_SECRET_TTL=31536000        # e.g. 365 days, in seconds
# Grace window in which the PREVIOUS secret stays valid after a rotation (zero-downtime rollover).
IAM_OAUTH_CLIENT_SECRET_GRACE=259200          # 72h, in SECONDS
# "Expiring soon" alert threshold (days) for the console banner + dashboard.
IAM_OAUTH_CLIENT_SECRET_WARN_DAYS=14
# Enable POST /oauth/client-secret so an auto-rotating app can self-fetch its new secret during the grace.
IAM_OAUTH_CLIENT_SELFFETCH=false
# private_key_jwt (RFC 7523): reject a client assertion whose lifetime (exp − iat) exceeds this many SECONDS.
# Caps the useful window of a stolen assertion (jti also makes it single-use). Default 300 (5 min).
IAM_OAUTH_CLIENT_ASSERTION_MAX_LIFETIME=300

#===============================================================================
# Server-side IdP sessions (revocable). All timeouts are in SECONDS.
#===============================================================================
IAM_SESSION_IDLE_TIMEOUT=1800           # re-auth after this much inactivity (30m)
IAM_SESSION_ABSOLUTE_TIMEOUT=43200      # hard ceiling, never extended (12h)
IAM_SESSION_STEPUP_WINDOW=300           # how long a step-up (2FA) stays satisfied (5m)
# IAM_SESSION_CONCURRENT_LIMIT=         # max concurrent sessions per subject (empty = unlimited)
IAM_SESSION_RETENTION_DAYS=90           # iam:prune-sessions deletes ended/expired rows older than this (DAYS)

#===============================================================================
# Client (in-app). The console runs server + client in one app → `local`.
#===============================================================================
IAM_CLIENT_MODE=local
# IAM_CLIENT_APP=
# IAM_CLIENT_ORG=

#===============================================================================
# AI module (advisory-only, sovereign-by-default)
#===============================================================================
# Off by default (sovereign, no data leaves the perimeter). Two real transports ship
# with laravel-iam-ai >= 1.2: `regolo` (EU, OpenAI-compatible) and `ollama` (on-prem).
# Fail-safe: a half-configured provider falls back to DisabledProvider (no network call).
IAM_AI_ENABLED=false
IAM_AI_PROVIDER=disabled            # disabled | regolo | ollama
IAM_AI_MODEL=
IAM_AI_STORE_OUTPUTS=false          # opt-in: persist sanitized outputs in audit
# Transport of the real provider (required to actually enable regolo/ollama):
# IAM_AI_BASE_URL=https://api.regolo.ai/v1   # or http://localhost:11434 for ollama
# IAM_AI_API_KEY=                            # required for regolo; optional for ollama
# IAM_AI_TIMEOUT=20

#===============================================================================
# Directory module (LDAP / Active Directory) — OPTIONAL, needs ext-ldap
#===============================================================================
# Enabling this requires the PHP `ldap` extension + `composer require
# directorytree/ldaprecord-laravel` and LdapRecord's own LDAP_* env. Leave false
# unless you have a real LDAP/AD to connect.
IAM_DIRECTORY_ENABLED=false
# IAM_DIRECTORY_ORG=
# LDAP_HOST=ldap.example.com
# LDAP_USERNAME="cn=admin,dc=example,dc=com"
# LDAP_PASSWORD=
# LDAP_PORT=389
# LDAP_BASE_DN="dc=example,dc=com"
# LDAP_SSL=false
# LDAP_TLS=false

#===============================================================================
# Bridge from spatie/laravel-permission — OPTIONAL (migration)
#===============================================================================
IAM_SPATIE_MODE=shadow              # shadow (compare) → then cutover
IAM_SPATIE_APP=app
# IAM_SPATIE_MISMATCH_CHANNEL=

#===============================================================================
# Audit / privacy
#===============================================================================
IAM_AUDIT_IP_MODE=hash              # hash | full | none  (full = readable IP/UA for forensics, needs TrustProxies)
IAM_AUDIT_UA_MODE=hash              # hash | full | none
IAM_AUDIT_IP_PEPPER=                # pepper for IP hashing (set a secret in prod)
# IAM_AUDIT_SINK=                   # external SIEM sink (optional)

#===============================================================================
# Observability / extras
#===============================================================================
# Tracer: null (off) | log (spans → local log) | otlp (native push to an OpenTelemetry
# collector) | stack (log + otlp). Requires laravel-iam-server >= 1.4 for otlp/stack.
IAM_TRACER=null
# IAM_TRACER_CHANNEL=                # dedicated log channel (for `log`/`stack`)
# OTLP push (for `otlp`/`stack`) — collector's HTTP receiver (port 4318); /v1/traces is appended:
# IAM_OTEL_ENDPOINT=http://otel-collector.observability.svc.cluster.local:4318
# IAM_OTEL_SERVICE_NAME=laravel-iam-console
# IAM_OTEL_TIMEOUT=5
IAM_RP_NAME="Laravel IAM"           # relying-party name (WebAuthn/passkey, when available)
IAM_INVITATIONS_ENABLED=auto
IAM_REBEL_ENABLED=auto              # advanced assurance (if laravel-iam-rebel installed)
IAM_MCP_ENABLED=false               # MCP server (v2, not installed here)
